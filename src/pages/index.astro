      >
        <img src="/icons/cursor.svg" alt="Cursor" width="18" height="18" />
      </a>
      </footer>
      </div>
    </main>

    <script is:inline>
      console.log(`;D`);
      (() => {
        const root = document.documentElement;
        const languageButton = document.querySelector("[data-language-button]");
        const menuButton = document.querySelector("[data-menu-button]");
        const menuPanel = document.querySelector("[data-menu-panel]");
        const navigation = document.querySelector("[data-navigation]");
        const socials = document.querySelector("[data-socials]");
        const description = document.querySelector("#page-description");

        const content = {
          fr: {
            title: "El-Amrani Youssef — Développeur Full-Stack",
            description:
              "El-Amrani Youssef — développeur full-stack et technologue créatif.",
            languageLabel: "Passer à l’arabe",
            navigationLabel: "Navigation principale",
            socialsLabel: "Réseaux sociaux et liens",
            openMenu: "Ouvrir le menu",
            closeMenu: "Fermer le menu",
          },
          ar: {
            title: "يوسف العمراني — مطوّر شامل",
            description:
              "يوسف العمراني — مطوّر شامل ومتخصص في التقنيات الإبداعية.",
            languageLabel: "الانتقال إلى الفرنسية",
            navigationLabel: "التنقل الرئيسي",
            socialsLabel: "روابط التواصل والحسابات",
            openMenu: "فتح القائمة",
            closeMenu: "إغلاق القائمة",
          },
        };

        const getLanguage = () =>
          root.dataset.language === "ar" ? "ar" : "fr";

        const menuIsOpen = () =>
          menuButton?.getAttribute("aria-expanded") === "true";

        const updateMenuLabel = () => {
          if (!menuButton) return;

          const language = getLanguage();
          const label = menuIsOpen()
            ? content[language].closeMenu
            : content[language].openMenu;

          menuButton.setAttribute("aria-label", label);
        };

        const setMenu = (open) => {
          if (!menuButton || !menuPanel) return;

          menuButton.setAttribute("aria-expanded", String(open));
          menuButton.classList.toggle("is-open", open);
          menuPanel.hidden = !open;
          updateMenuLabel();
        };

        const setLanguage = (language) => {
          const nextLanguage = language === "ar" ? "ar" : "fr";
          const translation = content[nextLanguage];

          root.dataset.language = nextLanguage;
          root.lang = nextLanguage;

          document.title = translation.title;
          description?.setAttribute("content", translation.description);
          languageButton?.setAttribute("aria-label", translation.languageLabel);
          navigation?.setAttribute("aria-label", translation.navigationLabel);
          socials?.setAttribute("aria-label", translation.socialsLabel);

          updateMenuLabel();

          try {
            localStorage.setItem("portfolio-language", nextLanguage);
          } catch {
            // Ignore storage errors.
          }
        };

        languageButton?.addEventListener("click", () => {
          setLanguage(getLanguage() === "fr" ? "ar" : "fr");
        });

        menuButton?.addEventListener("click", () => {
          setMenu(!menuIsOpen());
        });

        menuPanel?.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => setMenu(false));
        });

        document.addEventListener("click", (event) => {
          if (!menuIsOpen()) return;

          const target = event.target;
          if (!(target instanceof Node)) return;
          if (menuButton?.contains(target)) return;
          if (menuPanel?.contains(target)) return;

          setMenu(false);
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            setMenu(false);
            menuButton?.focus();
          }
        });

        setLanguage(getLanguage());
      })();
    </script>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Thmanyah Sans";
    src: url("/fonts/thmanyahsans-Regular.woff2") format("woff2");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Thmanyah Sans";
    src: url("/fonts/thmanyahsans-Bold.woff2") format("woff2");
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  :root {
    color-scheme: dark;
    --background: #050505;
    --surface: rgba(12, 12, 12, 0.88);
    --red: #b72d32;
    --white: #ffffff;
    --muted: rgba(255, 255, 255, 0.76);
    --border: rgba(255, 255, 255, 0.13);
    --latin-font: Helvetica, "Helvetica Neue", Arial, sans-serif;
    --arabic-font: "Thmanyah Sans", Arial, sans-serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html,
  body {
    min-width: 320px;
    min-height: 100%;
    margin: 0;
  }

  html {
    background: var(--background);
  }

  ::selection {
  background-color: var(--red); /* Changes the highlight box color (e.g., orange) */
  color: var(--white);            /* Changes the text color inside the highlight */
}

  body {
    overflow-x: hidden;
    background: var(--background);
    color: var(--white);
    font-family: var(--latin-font);
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  html[lang="ar"] body {
    font-family: var(--arabic-font);
  }

  html[data-language="fr"] .brand-name-ar,
  html[data-language="fr"] .hero-copy-ar,
  html[data-language="fr"] .description-ar,
  html[data-language="fr"] .copy-ar {
    display: none !important;
  }

  html[data-language="ar"] .brand-name-fr,
  html[data-language="ar"] .hero-copy-fr,
  html[data-language="ar"] .description-fr,
  html[data-language="ar"] .copy-fr {
    display: none !important;
  }

  a {
    color: inherit;
  }

  button {
    color: inherit;
    font: inherit;
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  a:focus-visible,
  button:focus-visible {
    outline: 2px solid var(--red);
    outline-offset: 4px;
  }

  .latin-text {
    display: inline-block;
    direction: ltr;
    font-family: var(--latin-font);
  }

  .hero {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: stretch;
    min-height: 100svh;
    overflow: hidden;
    isolation: isolate;
  }

  .stage {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: min(100%, 84rem);
    min-height: 100svh;
    margin: 0 auto;
    padding-inline: clamp(1.25rem, 3vw, 2.5rem);
  }

  .hero::before {
    position: absolute;
    z-index: -2;
    inset: 0;
    content: "";
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.76), rgba(0, 0, 0, 0.22)),
      url("/assets/HNCBoh7bIAAlVCE.jpeg") center / cover no-repeat;
  }

  html[data-language="ar"] .hero::before {
    background:
      linear-gradient(-90deg, rgba(0, 0, 0, 0.76), rgba(0, 0, 0, 0.22)),
      url("/assets/HNCBoh7bIAAlVCE.jpeg") center / cover no-repeat;
  }

  .hero::after {
    position: absolute;
    z-index: -1;
    inset: 0;
    content: "";
    pointer-events: none;
    background:
      radial-gradient(circle at 82% 22%, rgba(183, 45, 50, 0.14), transparent 34%),
      linear-gradient(to bottom, rgba(5, 5, 5, 0.04), rgba(5, 5, 5, 0.68));
  }

  html[data-language="ar"] .hero::after {
    background:
      radial-gradient(circle at 18% 22%, rgba(183, 45, 50, 0.14), transparent 34%),
      linear-gradient(to bottom, rgba(5, 5, 5, 0.04), rgba(5, 5, 5, 0.68));
  }

  .nav,
  .socials {
    flex-direction: row;
  }

  .nav {
    position: absolute;
    z-index: 40;
    top: 0;
    right: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    min-height: 5.6rem;
    padding: 1.4rem 0 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    min-width: 0;
    text-decoration: none;
  }

  .brand img {
    flex: 0 0 auto;
    width: clamp(2rem, 2.7vw, 2.5rem);
    height: clamp(2rem, 2.7vw, 2.5rem);
    object-fit: contain;
    filter: invert(1);
  }

  .brand-name {
    display: inline-flex;
    align-items: baseline;
    gap: 0.38rem;
    white-space: nowrap;
  }

  .brand-family {
    font-size: clamp(0.74rem, 1vw, 0.92rem);
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  html[lang="ar"] .brand-family {
    font-family: var(--arabic-font);
    font-size: clamp(0.9rem, 1.2vw, 1.08rem);
    letter-spacing: 0;
    text-transform: none;
  }

  .brand-firstname-latin {
    color: var(--red);
    font-family: "Bonheur Royale", cursive;
    font-size: clamp(1.45rem, 2.1vw, 1.95rem);
    line-height: 0.8;
    transform: rotate(-3deg);
  }

  .brand-firstname-arabic {
    color: var(--red);
    font-family: var(--arabic-font);
    font-size: 1.05em;
    font-weight: 700;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: clamp(0.65rem, 2vw, 1.4rem);
  }

  .language-button,
  .menu-button {
    border: 1px solid var(--border);
    background: rgba(5, 5, 5, 0.36);
    backdrop-filter: blur(12px);
    cursor: pointer;
  }

  .language-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.42rem;
    min-width: 4.7rem;
    min-height: 2.75rem;
    padding: 0.5rem 0.85rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    transition:
      border-color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }

  .language-choice-ar {
    font-family: var(--arabic-font);
    font-size: 1rem;
  }

  .language-separator {
    color: var(--red);
  }

  .language-button:hover,
  .menu-button:hover {
    border-color: rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.07);
  }

  .language-button:hover {
    transform: translateY(-1px);
  }

  .menu-button {
    display: grid;
    width: 2.85rem;
    height: 2.85rem;
    padding: 0;
    border-radius: 50%;
    place-content: center;
  }

  .menu-button span {
    display: block;
    width: 1.15rem;
    height: 1px;
    margin: 0.17rem 0;
    background: currentColor;
    transition:
      transform 180ms ease,
      margin 180ms ease;
  }

  .menu-button.is-open span {
    margin: -0.5px 0;
  }

  .menu-button.is-open span:first-child {
    transform: rotate(45deg);
  }

  .menu-button.is-open span:last-child {
    transform: rotate(-45deg);
  }

  .menu-panel {
    position: absolute;
    z-index: 50;
    top: 5.5rem;
    right: 0;
    display: grid;
    width: min(19rem, 100%);
    padding: 0.9rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: var(--surface);
    box-shadow: 0 1.4rem 4rem rgba(0, 0, 0, 0.42);
    backdrop-filter: blur(20px);
  }

  .menu-panel[hidden] {
    display: none;
  }

  .menu-panel a {
    display: flex;
    align-items: center;
    min-height: 3rem;
    padding: 0.65rem 0.75rem;
    border-radius: 0.72rem;
    text-decoration: none;
    transition: background 180ms ease;
  }

  .menu-panel a:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .accent-line {
    position: absolute;
    z-index: 0;
    pointer-events: none;
    background: rgba(183, 45, 50, 0.42);
  }

  .accent-line-horizontal {
    top: 37%;
    right: 0;
    left: 0;
    height: clamp(4px, 0.65vw, 9px);
  }

  .accent-line-vertical {
    top: 0;
    right: 12%;
    bottom: 0;
    width: clamp(4px, 0.65vw, 9px);
  }

  html[data-language="ar"] .accent-line-vertical {
    right: auto;
    left: 12%;
  }

  .intro {
    position: relative;
    z-index: 10;
    align-self: center;
    width: 100%;
    margin: 0;
    padding: 9rem 0 8rem;
  }

  html[data-language="ar"] .intro {
    direction: rtl;
  }

  .intro h1 {
    max-width: 72rem;
    margin: 0;
    font-family: var(--latin-font);
    line-height: 0.94;
  }

  html[lang="ar"] .intro h1 {
    font-family: var(--arabic-font);
  }

  .hero-copy {
    display: block;
